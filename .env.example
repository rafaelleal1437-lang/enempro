# ─────────────────────────────────────────────
#  ENEMPro Backend — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha
# ─────────────────────────────────────────────

# Porta (Railway define automaticamente)
PORT=3001

# Segredo do JWT — TROQUE por algo aleatório longo
JWT_SECRET=enempro-troque-por-algo-secreto-longo-aqui-2026

# ── E-MAIL (Gmail) ────────────────────────────
# Use um Gmail dedicado para o ENEMPro
EMAIL_USER=seuemail@gmail.com

# NÃO é a senha do Gmail normal!
# Vá em: myaccount.google.com → Segurança → Senhas de app
# Gere uma senha de app para "E-mail" e cole aqui
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── SITE ──────────────────────────────────────
# URL do seu site (aparece no botão do e-mail)
SITE_URL=https://seusite.com.br
